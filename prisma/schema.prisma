generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  passwordHash     String?
  stripeCustomerId String?
  loyaltyPoints    Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  sessions         Session[]
  bookings         Booking[]
  priceAlerts      PriceAlert[]
  travelerProfiles TravelerProfile[]
  savedTrips       SavedTrip[]
  paymentMethods   PaymentMethod[]
  preferences      UserPreferences?
  notifications    Notification[]
  hotelReviews     HotelReview[]
  carBookings      CarBooking[]
  packageReviews   PackageReview[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id            String  @id @default(cuid())
  userId        String  @unique
  currency      String  @default("USD")
  language      String  @default("en")
  timezone      String  @default("UTC")
  darkMode      Boolean @default(false)
  notifications Boolean @default(true)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TravelerProfile {
  id                String             @id @default(cuid())
  userId            String
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            String?
  nationality       String?
  passportNumber    String?
  passportExpiry    DateTime?
  phone             String?
  specialNeeds      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingPassengers BookingPassenger[]

  @@index([userId])
}

model SavedTrip {
  id           String   @id @default(cuid())
  userId       String
  name         String
  destination  String
  description  String?
  tripType     String
  searchParams Json
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Airline {
  id       String   @id @default(cuid())
  name     String
  iataCode String   @unique
  icaoCode String   @unique
  logoUrl  String?
  country  String?
  alliance String?
  flights  Flight[]
}

model Airport {
  id                String          @id @default(cuid())
  name              String
  city              String
  country           String
  iataCode          String          @unique
  icaoCode          String          @unique
  timezone          String
  latitude          Float
  longitude         Float
  country_code      String
  departureFlights  Flight[]        @relation("DepartureAirport")
  arrivalFlights    Flight[]        @relation("ArrivalAirport")
  departureSegments FlightSegment[] @relation("SegmentDepartureAirport")
  arrivalSegments   FlightSegment[] @relation("SegmentArrivalAirport")
}

model Flight {
  id                 String               @id @default(cuid())
  flightNumber       String
  airlineId          String
  departureTime      DateTime
  arrivalTime        DateTime
  departureAirportId String
  arrivalAirportId   String
  aircraftType       String?
  duration           Int
  stops              Int                  @default(0)
  basePrice          Float
  currency           String               @default("USD")
  status             String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  airline            Airline              @relation(fields: [airlineId], references: [id])
  departureAirport   Airport              @relation("DepartureAirport", fields: [departureAirportId], references: [id])
  arrivalAirport     Airport              @relation("ArrivalAirport", fields: [arrivalAirportId], references: [id])
  flightSegments     FlightSegment[]
  priceHistory       FlightPriceHistory[]
  flightBookings     FlightBooking[]

  @@index([airlineId])
  @@index([departureAirportId])
  @@index([arrivalAirportId])
}

model FlightSegment {
  id                 String   @id @default(cuid())
  flightId           String
  departureTime      DateTime
  arrivalTime        DateTime
  departureAirportId String
  arrivalAirportId   String
  aircraftType       String?
  duration           Int
  segmentOrder       Int
  flight             Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  departureAirport   Airport  @relation("SegmentDepartureAirport", fields: [departureAirportId], references: [id])
  arrivalAirport     Airport  @relation("SegmentArrivalAirport", fields: [arrivalAirportId], references: [id])
}

model FlightPriceHistory {
  id       String   @id @default(cuid())
  flightId String
  date     DateTime @default(now())
  price    Float
  currency String   @default("USD")
  flight   Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@index([flightId, date])
}

model Hotel {
  id           String        @id @default(cuid())
  name         String
  description  String?
  address      String
  city         String
  state        String
  country      String
  zipCode      String
  latitude     Float
  longitude    Float
  starRating   Int?
  guestRating  Float?
  reviewCount  Int           @default(0)
  amenities    String[]
  checkInTime  String
  checkOutTime String
  images       String[]
  website      String?
  phone        String?
  email        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  roomTypes    RoomType[]
  reviews      HotelReview[]

  @@index([city, country])
  @@index([starRating])
}

model RoomType {
  id           String         @id @default(cuid())
  hotelId      String
  name         String
  description  String?
  size         String?
  bedType      String?
  maxOccupancy Int            @default(2)
  amenities    String[]
  images       String[]
  basePrice    Float
  currency     String         @default("USD")
  isAvailable  Boolean        @default(true)
  hotel        Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelBookings HotelBooking[]

  @@index([hotelId])
}

model HotelReview {
  id        String   @id @default(cuid())
  hotelId   String
  userId    String
  rating    Int
  title     String
  comment   String?
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model CarRental {
  id           String       @id @default(cuid())
  provider     String
  name         String
  description  String?
  category     String
  seats        Int
  luggageSpace Int
  transmission String
  fuelPolicy   String
  features     String[]
  dailyRate    Float
  currency     String       @default("USD")
  imageUrls    String[]
  location     String
  latitude     Float
  longitude    Float
  rating       Float?
  reviewCount  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  carBookings  CarBooking[]

  @@index([category])
  @@index([location])
}

model CarBooking {
  id              String    @id @default(cuid())
  carRentalId     String
  userId          String
  bookingId       String
  pickUpLocation  String
  dropOffLocation String
  pickUpTime      DateTime
  dropOffTime     DateTime
  driverAge       Int
  totalCost       Float
  currency        String    @default("USD")
  status          String    @default("confirmed")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  carRental       CarRental @relation(fields: [carRentalId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Booking {
  id               String             @id @default(cuid())
  userId           String
  bookingReference String             @unique
  bookingType      String
  status           String             @default("confirmed")
  totalAmount      Float
  currency         String             @default("USD")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  confirmationDate DateTime?
  paymentIntentId  String?
  user             User               @relation(fields: [userId], references: [id])
  flightBookings   FlightBooking[]
  hotelBookings    HotelBooking[]
  carBookings      CarBooking[]
  packageBookings  PackageBooking[]
  passengers       BookingPassenger[]
  payments         Payment[]
}

model FlightBooking {
  id           String        @id @default(cuid())
  bookingId    String
  flightId     String
  seatNumber   String?
  travelClass  String
  fareType     String
  baseFare     Float
  taxesFees    Float         @default(0)
  totalFare    Float
  currency     String        @default("USD")
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  flight       Flight        @relation(fields: [flightId], references: [id])
  addons       FlightAddon[]
}

model FlightAddon {
  id              String        @id @default(cuid())
  flightBookingId String
  type            String
  description     String
  price           Float
  currency        String        @default("USD")
  flightBooking   FlightBooking @relation(fields: [flightBookingId], references: [id], onDelete: Cascade)
}

model HotelBooking {
  id              String         @id @default(cuid())
  bookingId       String
  roomTypeId      String
  checkIn         DateTime
  checkOut        DateTime
  numberOfNights  Int
  numberOfGuests  Int
  baseRate        Float
  taxesFees       Float          @default(0)
  totalCost       Float
  currency        String         @default("USD")
  specialRequests String?
  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType        RoomType       @relation(fields: [roomTypeId], references: [id])
  guests          BookingGuest[]
}

model BookingPassenger {
  id                String           @id @default(cuid())
  bookingId         String
  travelerProfileId String?
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            String?
  nationality       String?
  passportNumber    String?
  passengerType     String
  seatNumber        String?
  booking           Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  travelerProfile   TravelerProfile? @relation(fields: [travelerProfileId], references: [id], onDelete: SetNull)
}

model BookingGuest {
  id             String       @id @default(cuid())
  hotelBookingId String
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  gender         String?
  hotelBooking   HotelBooking @relation(fields: [hotelBookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  paymentMethodId String
  amount          Float
  currency        String        @default("USD")
  status          String
  stripePaymentId String?
  transactionId   String?
  provider        String
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

model PaymentMethod {
  id          String    @id @default(cuid())
  userId      String
  type        String
  provider    String
  last4       String?
  brand       String?
  expiryMonth Int?
  expiryYear  Int?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments    Payment[]
}

model PriceAlert {
  id            String    @id @default(cuid())
  userId        String
  searchType    String
  destination   String
  origin        String?
  departureDate DateTime?
  checkInDate   DateTime?
  checkOutDate  DateTime?
  currentPrice  Float
  targetPrice   Float?
  isNotified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  lastChecked   DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Package {
  id              String          @id @default(cuid())
  name            String
  description     String
  destination     String
  duration        Int
  images          String[]
  inclusions      String[]
  exclusions      String[]
  minPrice        Float
  maxPrice        Float?
  currency        String          @default("USD")
  rating          Float?
  reviewCount     Int             @default(0)
  availableDates  DateTime[]
  provider        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  packageBookings PackageBooking[]
  reviews         PackageReview[]

  @@index([destination])
}

model PackageBooking {
  id             String         @id @default(cuid())
  bookingId      String
  packageId      String
  startDate      DateTime
  endDate        DateTime
  numberOfPeople Int
  basePrice      Float
  taxesFees      Float          @default(0)
  totalCost      Float
  currency       String         @default("USD")
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package        Package        @relation(fields: [packageId], references: [id])
  packageGuests  PackageGuest[]
}

model PackageGuest {
  id               String         @id @default(cuid())
  packageBookingId String
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  gender           String?
  isLead           Boolean        @default(false)
  packageBooking   PackageBooking @relation(fields: [packageBookingId], references: [id], onDelete: Cascade)
}

model PackageReview {
  id        String   @id @default(cuid())
  packageId String
  userId    String
  rating    Int
  title     String
  comment   String?
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([packageId])
}lib/auth.tslib/auth.ts